<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Profile photo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="1dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/primaryContainer">

            <ImageView
                android:id="@+id/ivTeamPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_placeholder"
                tools:ignore="ContentDescription" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Text details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/tvTeamName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/onSurface"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Md. Karim Uddin" />

            <TextView
                android:id="@+id/tvTeamRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                tools:text="Chairperson" />

            <TextView
                android:id="@+id/tvTeamInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="CSE, Batch 45" />
        </LinearLayout>

        <!-- Email button -->
        <ImageButton
            android:id="@+id/btnTeamEmail"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_button"
            android:src="@drawable/ic_send"
            android:scaleType="centerInside"
            android:padding="10dp"
            android:contentDescription="@string/committee_email_member"
            app:tint="@color/primary" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

